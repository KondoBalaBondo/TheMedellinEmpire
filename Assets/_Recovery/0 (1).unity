--- !u!114 &1766375752
MonoBehaviour:
  m_ObjectHideFlags: 2
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 1766375741}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: ec422cd568a9c4a31ad7c36d0572b9da, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Fungus::Fungus.Say
  itemId: 5
  indentLevel: 0
  storyText: "[Carlos] \nEgy r\xE9gi haver, de ne h\xFAzd fel. Komoly fick\xF3, de
    ha bizony\xEDtasz, rendes lesz."
  description: 
  character: {fileID: 0}
  portrait: {fileID: 0}
  voiceOverClip: {fileID: 8300000, guid: 768c9a58c77a730459a6658580ed2062, type: 3}
  showAlways: 1
  showCount: 1
  extendPrevious: 0
