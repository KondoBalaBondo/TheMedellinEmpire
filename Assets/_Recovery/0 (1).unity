  waitForVO: 0
  setSayDialog: {fileID: 0}
--- !u!114 &1766375758
MonoBehaviour:
  m_ObjectHideFlags: 2
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 1766375741}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: ec422cd568a9c4a31ad7c36d0572b9da, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Fungus::Fungus.Say
  itemId: 13
  indentLevel: 0
  storyText: "[Carlos] \nEsetleg itt a falu sz\xE9l\xE9n Cost\xE1nak tudsz hozni
    gomb\xE1t eladni. "
  description: 
  character: {fileID: 0}
  portrait: {fileID: 0}
  voiceOverClip: {fileID: 8300000, guid: 00b733246d30c9b4e939ceaa0e36a598, type: 3}
  showAlways: 1
  showCount: 1
  extendPrevious: 0
  fadeWhenDone: 0
  waitForClick: 0
  stopVoiceover: 1
  waitForVO: 0
  setSayDialog: {fileID: 0}
--- !u!114 &1766375759
MonoBehaviour:
  m_ObjectHideFlags: 2
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 1766375741}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: ec422cd568a9c4a31ad7c36d0572b9da, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Fungus::Fungus.Say
  itemId: 20
  indentLevel: 0
  storyText: "[Carlos] \nAhogy elhagyod ezt a falut az els\u0151 lehet\u0151s\xE9gn\xE9l
    fordulj balra \xE9s meg se \xE1llj az \xFAt v\xE9g\xE9ig ott fogod jobb oldalt
    tal\xE1lni Juan Santos birtok\xE1t."
  description: 
  character: {fileID: 0}
  portrait: {fileID: 0}
  voiceOverClip: {fileID: 8300000, guid: 6be99b9b76188ff458531ddb2fb1fa32, type: 3}
  showAlways: 1
  showCount: 1
  extendPrevious: 0
  fadeWhenDone: 1
  waitForClick: 0
  stopVoiceover: 1
  waitForVO: 0
  setSayDialog: {fileID: 0}
