  m_EditorClassIdentifier: Fungus::Fungus.Say
  itemId: 9
  indentLevel: 0
  storyText: "[Miguel] \nAzt\xE1n ahol visszamenne az \xFAt a faluba\u2026\nnem arra
    m\xE9sz."
  description: 
  character: {fileID: 0}
  portrait: {fileID: 0}
