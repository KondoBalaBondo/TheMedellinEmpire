--- !u!114 &1766375755
MonoBehaviour:
  m_ObjectHideFlags: 2
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 1766375741}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: ec422cd568a9c4a31ad7c36d0572b9da, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Fungus::Fungus.Say
  itemId: 12
  indentLevel: 0
  storyText: "[Carlos]\nMenj le oda, k\xE9rdezd meg Juan Santost - mondd, hogy Carlos
    k\xFCld\xF6tt."
  description: 
  character: {fileID: 0}
  portrait: {fileID: 0}
  voiceOverClip: {fileID: 8300000, guid: 00fc01a4145a56347a134408632b1cd8, type: 3}
  showAlways: 1
  showCount: 1
  extendPrevious: 0
  fadeWhenDone: 0
  waitForClick: 0
  stopVoiceover: 1
  waitForVO: 0
  setSayDialog: {fileID: 0}
--- !u!114 &1766375756
MonoBehaviour:
  m_ObjectHideFlags: 2
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 1766375741}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: ec422cd568a9c4a31ad7c36d0572b9da, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Fungus::Fungus.Say
  itemId: 15
  indentLevel: 0
  storyText: "[Carlos] \nGomb\xE1t a h\xEDd el\u0151tt tudsz szedni ahol ki vannak
    v\xE1gva a f\xE1k ott vannak a j\xF3 f\xE9l\xE9k.\n"
  description: 
  character: {fileID: 0}
  portrait: {fileID: 0}
  voiceOverClip: {fileID: 8300000, guid: 61578106974798a4da292a6da3caa692, type: 3}
  showAlways: 1
  showCount: 1
  extendPrevious: 0
  fadeWhenDone: 0
  waitForClick: 0
  stopVoiceover: 1
  waitForVO: 0
  setSayDialog: {fileID: 0}
--- !u!114 &1766375757
MonoBehaviour:
  m_ObjectHideFlags: 2
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 1766375741}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: ec422cd568a9c4a31ad7c36d0572b9da, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Fungus::Fungus.Say
  itemId: 14
  indentLevel: 0
  storyText: "[Carlos] \nDe hidd el abbol nem lesz sok p\xE9nzed te d\xF6ntesz!"
  description: 
  character: {fileID: 0}
  portrait: {fileID: 0}
  voiceOverClip: {fileID: 8300000, guid: e149dd857ea6a68478089d3be8f10856, type: 3}
  showAlways: 1
  showCount: 1
  extendPrevious: 0
  fadeWhenDone: 0
