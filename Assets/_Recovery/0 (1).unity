  m_EditorClassIdentifier: Assembly-CSharp::DialogueEditor.NPCConversation
  CurrentIDCounter: 9
  json: "{\"Options\":[{\"Connections\":[{\"__type\":\"EditableSpeechConnection:#DialogueEditor\",\"Conditions\":[],\"NodeUID\":6}],\"EditorInfo\":{\"isRoot\":false,\"xPos\":-65,\"yPos\":512},\"ID\":3,\"ParamActions\":[],\"TMPFontGUID\":null,\"Text\":\"Tudsz
    k\xF6lcs\xF6nadni egy aut\xF3t?\",\"parentUIDs\":[8],\"SpeechUID\":-1},{\"Connections\":[{\"__type\":\"EditableSpeechConnection:#DialogueEditor\",\"Conditions\":[],\"NodeUID\":5}],\"EditorInfo\":{\"isRoot\":false,\"xPos\":-61,\"yPos\":138},\"ID\":4,\"ParamActions\":[],\"TMPFontGUID\":null,\"Text\":\"Ki
    ez a Juan Santos?\",\"parentUIDs\":[0],\"SpeechUID\":-1},{\"Connections\":[{\"__type\":\"EditableSpeechConnection:#DialogueEditor\",\"Conditions\":[],\"NodeUID\":8}],\"EditorInfo\":{\"isRoot\":false,\"xPos\":-60,\"yPos\":324},\"ID\":7,\"ParamActions\":[],\"TMPFontGUID\":null,\"Text\":\"Mi
    van, ha nemet mondok a mel\xF3ra?\",\"parentUIDs\":[5],\"SpeechUID\":-1}],\"Parameters\":[],\"SpeechNodes\":[{\"Connections\":[{\"__type\":\"EditableOptionConnection:#DialogueEditor\",\"Conditions\":[],\"NodeUID\":4}],\"EditorInfo\":{\"isRoot\":true,\"xPos\":-65,\"yPos\":22},\"ID\":0,\"ParamActions\":[],\"TMPFontGUID\":null,\"Text\":\"H\xE9,
    hermano!! Hallottam, mel\xF3t keresel. Van egy arc a k\xFClv\xE1rosi r\xE9szen,
    akinek mindig kell egy \xFCgyes k\xE9z. Menj le oda, k\xE9rdezd meg Juan Santost
    - mondd, hogy Carlos k\xFCld\xF6tt.\",\"parentUIDs\":[],\"AdvanceDialogueAutomatically\":false,\"AudioGUID\":null,\"AutoAdvanceShouldDisplayOption\":false,\"IconGUID\":null,\"Name\":\"[Carlos]\",\"OptionUIDs\":null,\"SpeechUID\":0,\"TimeUntilAdvance\":0,\"Volume\":0},{\"Connections\":[{\"__type\":\"EditableOptionConnection:#DialogueEditor\",\"Conditions\":[],\"NodeUID\":7}],\"EditorInfo\":{\"isRoot\":false,\"xPos\":-66,\"yPos\":212},\"ID\":5,\"ParamActions\":[],\"TMPFontGUID\":null,\"Text\":\"Egy
    r\xE9gi haver, de ne h\xFAzd fel. Komoly fick\xF3, de ha bizony\xEDtasz, rendes
    lesz.\",\"parentUIDs\":[4],\"AdvanceDialogueAutomatically\":false,\"AudioGUID\":null,\"AutoAdvanceShouldDisplayOption\":false,\"IconGUID\":null,\"Name\":\"Carlos\",\"OptionUIDs\":null,\"SpeechUID\":0,\"TimeUntilAdvance\":0,\"Volume\":0},{\"Connections\":[],\"EditorInfo\":{\"isRoot\":false,\"xPos\":-69,\"yPos\":590},\"ID\":6,\"ParamActions\":[],\"TMPFontGUID\":null,\"Text\":\"Persze,
    az \xE9p\xFClet mellett \xE1ll, oldalt. Csak ne karcold \xF6ssze, j\xF3? Tess\xE9k
    itt egy pisztoly ez legyen n\xE1lad vesz\xE9lyes k\xF6rny\xE9ken vagyunk. Ahogy
    elhagyod a falut els\u0151 lehet\u0151s\xE9gn\xE9l fordulj balra \xE9s az utca
    v\xE9g\xE9ig meg se \xE1llj, ott fogod tal\xE1lni Juan Santos birtok\xE1t.\",\"parentUIDs\":[3],\"AdvanceDialogueAutomatically\":false,\"AudioGUID\":null,\"AutoAdvanceShouldDisplayOption\":false,\"IconGUID\":null,\"Name\":\"Carlos\",\"OptionUIDs\":null,\"SpeechUID\":0,\"TimeUntilAdvance\":0,\"Volume\":0},{\"Connections\":[{\"__type\":\"EditableOptionConnection:#DialogueEditor\",\"Conditions\":[],\"NodeUID\":3}],\"EditorInfo\":{\"isRoot\":false,\"xPos\":-62,\"yPos\":408},\"ID\":8,\"ParamActions\":[],\"TMPFontGUID\":null,\"Text\":\"Akkor
    maradsz p\xE9nz n\xE9lk\xFCl, hermano. Itt nem sok m\xE1s v\xE1laszt\xE1s van.\",\"parentUIDs\":[7],\"AdvanceDialogueAutomatically\":false,\"AudioGUID\":null,\"AutoAdvanceShouldDisplayOption\":false,\"IconGUID\":null,\"Name\":\"Carlos\",\"OptionUIDs\":null,\"SpeechUID\":0,\"TimeUntilAdvance\":0,\"Volume\":0}]}"
