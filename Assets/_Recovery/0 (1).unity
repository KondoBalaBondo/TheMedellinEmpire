  m_Name: 
  m_EditorClassIdentifier: Fungus::Fungus.Say
  itemId: 16
  indentLevel: 0
  storyText: "[Carlos] \nTess\xE9k itt egy pisztoly [1-es gomb az el\u0151v\xE9telhez]
    ez legyen n\xE1lad vesz\xE9lyes emberekkel tal\xE1lkozhatsz erre fel\xE9."
  description: 
  character: {fileID: 0}
  portrait: {fileID: 0}
