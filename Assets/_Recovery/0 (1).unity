  m_EditorClassIdentifier: Fungus::Fungus.Say
  itemId: 8
  indentLevel: 0
  storyText: "[Miguel] \nBalra fordulsz. Az vezet fel a hegyre."
  description: 
  character: {fileID: 0}
  portrait: {fileID: 0}
  voiceOverClip: {fileID: 8300000, guid: 0adea577d952a6a4b8610ccc5e3ff0e7, type: 3}
