  text: "[Te] \nTudsz k\xF6lcs\xF6n adni egy aut\xF3t?"
  description: 
  targetBlock: {fileID: 1766375747}
  hideIfVisited: 0
  interactable:
    booleanRef: {fileID: 0}
    booleanVal: 1
  setMenuDialog: {fileID: 0}
