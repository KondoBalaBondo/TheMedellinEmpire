  m_Name: 
  m_EditorClassIdentifier: Fungus::Fungus.Say
  itemId: 7
  indentLevel: 0
  storyText: "[Miguel] \nFel\xE9rsz ott jobbra bekanyarodsz a rept\xE9rre, lerakod
    a cuccot, \xE9s nem maradsz ott tov\xE1bb a kellet\xE9n\xE9l.\n"
  description: 
  character: {fileID: 0}
  portrait: {fileID: 0}
