  m_Name: 
  m_EditorClassIdentifier: Fungus::Fungus.Menu
  itemId: 6
  indentLevel: 0
  text: "[Te] \nMi van, ha nemet mondok a mel\xF3ra?"
  description: 
  targetBlock: {fileID: 1766375750}
  hideIfVisited: 0
  interactable:
    booleanRef: {fileID: 0}
    booleanVal: 1
