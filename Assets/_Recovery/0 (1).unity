  m_Name: 
  m_EditorClassIdentifier: Fungus::Fungus.Say
  itemId: 8
  indentLevel: 0
  storyText: "[Carlos] \nAkkor maradsz p\xE9nz n\xE9lk\xFCl, hermano."
  description: 
  character: {fileID: 0}
  portrait: {fileID: 0}
  voiceOverClip: {fileID: 8300000, guid: 79e58d55fcd869443a5464df278d395b, type: 3}
