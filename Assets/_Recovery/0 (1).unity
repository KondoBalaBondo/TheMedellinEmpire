  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: ec422cd568a9c4a31ad7c36d0572b9da, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Fungus::Fungus.Say
  itemId: 10
  indentLevel: 0
  storyText: "[Miguel] \nAz utat egyszer\u0171 megtal\xE1lni.\nLem\xE9sz itt a dombr\xF3l
    vissza a v\xE1ros fel\xE9,  jobbra fordulsz, \xE9s m\xE9sz egyenesen v\xE9gig."
  description: 
  character: {fileID: 0}
  portrait: {fileID: 0}
  voiceOverClip: {fileID: 8300000, guid: 02d0691706d606c4994b97086e2a8103, type: 3}
  showAlways: 1
  showCount: 1
  extendPrevious: 0
  fadeWhenDone: 1
  waitForClick: 0
  stopVoiceover: 1
  waitForVO: 0
  setSayDialog: {fileID: 0}
--- !u!114 &1676660594
