  m_EditorClassIdentifier: Fungus::Fungus.Menu
  itemId: 3
  indentLevel: 0
  text: "[Te] \nKi ez a Juan Santos?\n"
  description: 
  targetBlock: {fileID: 1766375753}
  hideIfVisited: 0
  interactable:
    booleanRef: {fileID: 0}
    booleanVal: 1
  setMenuDialog: {fileID: 0}
